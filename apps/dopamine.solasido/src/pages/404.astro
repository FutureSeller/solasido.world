---
import Layout from '../layouts/Layout.astro'
import { SITE_NAME } from '../lib/site-meta'
---

<Layout
  title={`404 | ${SITE_NAME}`}
  description="요청하신 페이지를 찾을 수 없습니다."
>
  <main class="mx-auto flex min-h-[70vh] w-[min(92vw,700px)] flex-col items-center justify-center text-center">
    <p class="mb-3 text-sm opacity-60">404 Not Found</p>
    <h1 class="mb-4 text-3xl font-bold">페이지를 찾을 수 없어요</h1>
    <p class="mb-8 text-base opacity-70">
      주소가 변경되었거나 삭제된 페이지일 수 있습니다.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center rounded-lg border border-border px-5 py-2.5 hover:bg-muted transition-colors"
    >
      홈으로 돌아가기
    </a>
  </main>
</Layout>
